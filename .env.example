# Jira
EXTAPI_JIRA_BASE_URL=https://yourco.atlassian.net
EXTAPI_JIRA_USER_EMAIL=you@yourco.com
EXTAPI_JIRA_API_TOKEN=your-atlassian-api-token

# Bitbucket
EXTAPI_BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0
EXTAPI_BITBUCKET_USER_EMAIL=you@yourco.com
EXTAPI_BITBUCKET_API_TOKEN=your-bitbucket-api-token

# Slack
EXTAPI_SLACK_BASE_URL=https://slack.com/api
EXTAPI_SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Gmail
EXTAPI_GMAIL_BASE_URL=https://gmail.googleapis.com

# Google Drive
EXTAPI_GDRIVE_BASE_URL=https://www.googleapis.com

# Google Calendar
EXTAPI_GCALENDAR_BASE_URL=https://www.googleapis.com

# Google OAuth (for per-user Workspace auth)
EXTAPI_GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
EXTAPI_GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
EXTAPI_GOOGLE_AUTH_DB_PATH=extapi_google_auth.db

# Fallback option for Google services
EXTAPI_GOOGLE_ACCESS_TOKEN=your-google-oauth2-access-token

# Feature flags
EXTAPI_DRY_RUN_DELETES=false

# Per-service approval gates — comma-separated HTTP methods (post,put,patch,delete)
# Empty = no approval required. Example: EXTAPI_REQUIRE_APPROVAL_JIRA=post,put,delete
EXTAPI_REQUIRE_APPROVAL_JIRA=
EXTAPI_REQUIRE_APPROVAL_BITBUCKET=
EXTAPI_REQUIRE_APPROVAL_SLACK=
EXTAPI_REQUIRE_APPROVAL_GMAIL=
EXTAPI_REQUIRE_APPROVAL_GDRIVE=
EXTAPI_REQUIRE_APPROVAL_GCALENDAR=
EXTAPI_REVIEW_DB_PATH=extapi_review.db

# Server
EXTAPI_HOST=127.0.0.1
EXTAPI_PORT=11583
